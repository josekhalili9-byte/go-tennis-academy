rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
       return request.auth != null;
    }
    
    function isOwner(userId) {
       return isAuthenticated() && request.auth.uid == userId;
    }

    // Default admin definition for prototype
    function isAdmin() {
       return isAuthenticated() && request.auth.token.email == 'josekhalili9@gmail.com';
    }

    match /users/{userId} {
      // Users can only read and write their own documents, admins can read/write all
      allow read, write: if isOwner(userId) || isAdmin();
    }
    
    match /reservations/{reservationId} {
      // Allow read so calendar can check availability
      allow read: if true; 
      // Allow create if auth matches userId
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid || isAdmin();
      // Allow delete/update for now for demo purposes
      allow update, delete: if true;
    }
  }
}
